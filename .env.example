# KingdomOS — Environment Variables
# Copy this file to .env and fill in your API keys.

# OpenAI API key (required for most tiers)
OPENAI_API_KEY=sk-proj-...

# OpenRouter API key (optional, for alternative model routing)
OPENROUTER_API_KEY=sk-or-v1-...

# LM Studio (optional, for local models — ensure LM Studio is running at http://localhost:1234)
# No key needed; just set the provider endpoint in kingdom.config.json
