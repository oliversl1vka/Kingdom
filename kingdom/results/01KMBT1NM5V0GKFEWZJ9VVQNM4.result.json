  "content": "```diff\ndiff --git a/src/render/room_floor_renderer.py b/src/render/room_floor_renderer.py\nnew file mode 100644\nindex 0000000..d4a3b7c\n--- /dev/null\n+++ b/src/render/room_floor_renderer.py\n@@ -0,0 +1,120 @@\n+\"\"\"\n+Room Floor Renderer\n+\n+This module implements tilemap-based floor rendering for rooms.\n+Each room floor is rendered using 16x16 tiles with variants for stone,\n+wood, carpet, and cobblestone floor types.\n+\"\"\"\n+\n+import pygame\n+from pygame import Surface, Rect\n+\n+TILE_SIZE = 16\n+\n+class FloorTileSet:\n+    \"\"\"\n+    Holds tile variants for a floor type.\n+    Each tile type has multiple variants to add visual variety.\n+    \"\"\"\n+    def __init__(self, tile_images):\n+        \"\"\"\n+        tile_images: list of pygame.Surface objects representing tile variants\n+        \"\"\"\n+        self.tiles = tile_images\n+        self.variant_count = len(tile_images)\n+\n+    def get_variant(self, x, y):\n+        \"\"\"\n+        Return a tile variant based on position to add pattern variety.\n+        \"\"\"\n+        # Simple pattern: variant index depends on tile coordinates\n+        idx = (x + y) % self.variant_count\n+        return self.tiles[idx]\n+\n+\n+class RoomFloorRenderer:\n+    \"\"\"\n+    Renders the floor of a room using tilemaps.\n+    \"\"\"\n+    def __init__(self, tile_sets):\n+        \"\"\"\n+        tile_sets: dict mapping floor type string to FloorTileSet\n+        e.g. {\n+            'stone': FloorTileSet([...]),\n+            'wood': FloorTileSet([...]),\n+            'carpet': FloorTileSet([...]),\n+            'cobblestone': FloorTileSet([...]),\n+        }\n+        \"\"\"\n+        self.tile_sets = tile_sets\n+\n+    def render_floor(self, surface: Surface, room_rect: Rect, floor_type: str):\n+        \"\"\"\n+        Render the floor tiles on the given surface within room_rect.\n+\n+        surface: pygame.Surface to draw on\n+        room_rect: pygame.Rect defining room position and size in pixels\n+        floor_type: string key for floor tile set\n+        \"\"\"\n+        if floor_type not in self.tile_sets:\n+            raise ValueError(f\"Unknown floor type: {floor_type}\")\n+\n+        tile_set = self.tile_sets[floor_type]\n+\n+        tiles_x = room_rect.width // TILE_SIZE\n+        tiles_y = room_rect.height // TILE_SIZE\n+\n+        for ty in range(tiles_y):\n+            for tx in range(tiles_x):\n+                tile_img = tile_set.get_variant(tx, ty)\n+                dest_x = room_rect.x + tx * TILE_SIZE\n+                dest_y = room_rect.y + ty * TILE_SIZE\n+                surface.blit(tile_img, (dest_x, dest_y))\n+\n+\n+# Helper function to load tile images from files\n+def load_tile_images(base_path, count):\n+    \"\"\"\n+    Load tile images from base_path with indices 0..count-1.\n+    Expects files named base_path0.png, base_path1.png, etc.\n+    \"\"\"\n+    images = []\n+    for i in range(count):\n+        path = f\"{base_path}{i}.png\"\n+        img = pygame.image.load(path).convert_alpha()\n+        images.append(img)\n+    return images\n+\n+\n+# Example usage (to be integrated in game initialization):\n+#\n+# stone_tiles = FloorTileSet(load_tile_images(\"assets/tiles/stone_\", 4))\n+# wood_tiles = FloorTileSet(load_tile_images(\"assets/tiles/wood_\", 4))\n+# carpet_tiles = FloorTileSet(load_tile_images(\"assets/tiles/carpet_\", 4))\n+# cobblestone_tiles = FloorTileSet(load_tile_images(\"assets/tiles/cobblestone_\", 4))\n+#\n+# floor_renderer = RoomFloorRenderer({\n+#     \"stone\": stone_tiles,\n+#     \"wood\": wood_tiles,\n+#     \"carpet\": carpet_tiles,\n+#     \"cobblestone\": cobblestone_tiles,\n+# })\n+#\n+# # Then call floor_renderer.render_floor(surface, room_rect, room_floor_type)\n+#\n+#\n+# This module focuses on floor rendering only.\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#\n+#