# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# installed agent skills + tooling (reinstallable) + local server logs
/.agents/
/.claude/
AGENTS.md
skills-lock.json
.server*.log

# local verification screenshots (test artifacts)
/.verify-screenshots/

# Playwright — keep committed: the visual baselines (tests/__screenshots__) and
# the curated galleries (playwright/survey, /shots, /ios-real). Ignore the bulky
# regenerable artifacts: the HTML report (~90M) and per-test videos/traces.
/playwright/report/
/playwright/test-results/
/test-results/
/playwright/.cache/
