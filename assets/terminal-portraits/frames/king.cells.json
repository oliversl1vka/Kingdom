{"w": 64, "h": 47, "braille": ["\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2810\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ef\u2800\u2800\u28e2\u28ff\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u28e0\u2800\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u28e0\u28c4\u2840\u28c0\u2800\u2800\u2800\u28a0\u28f4\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c7\u28df\u28ff\u28ff\u28e4\u2842\u2800\u2803\u2802\u2800\u2800\u2800\u28c4\u2803\u2840\u2800\u2800\u2800\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2888\u28ff\u2802\u2800\u2800\u2800\u2800\u2800\u2820\u28b0\u28ff\u28ff\u28f7\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u284f\u28f9\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u28ff\u28ff\u28ff\u28fe\u28ee\u2800\u2800\u28e4\u2800\u2800\u287f\u28a8\u2801\u2800\u2800\u2800\u2800", "\u2800\u2800\u2800\u2840\u2880\u28b0\u2844\u2800\u2800\u2800\u2800\u2800\u2800\u2810\u28a1\u28b8\u28f7\u2846\u2800\u2800\u2800\u2800\u2800\u2800\u28b8\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u281b\u281b\u28eb\u2847\u2800\u280a\u2819\u281f\u281b\u28bf\u283f\u2841\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ee\u28c6\u28ff\u28c4\u2800\u2821\u2800\u2800\u2800\u2800\u2800\u2800", "\u2800\u2800\u2800\u2841\u2818\u2838\u280f\u2841\u2800\u2800\u2800\u2800\u2800\u2800\u2810\u28b8\u28cf\u2803\u2800\u2800\u2800\u2800\u2800\u2800\u283d\u287f\u287f\u28ff\u28ff\u287f\u28a7\u280b\u2801\u28e7\u28e7\u2874\u289b\u2847\u2806\u28a0\u28c1\u2800\u2800\u2800\u2810\u2800\u28a9\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2821\u2800\u2840\u2800\u28ee\u2810\u2800\u2800\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2880\u284c\u28f7\u2808\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2831\u28ee\u28f5\u28ff\u286f\u281b\u2891\u28f6\u2808\u28ff\u287f\u283f\u283e\u2820\u2806\u2839\u281f\u2800\u2800\u2830\u2800\u2800\u2800\u2808\u2819\u28f9\u28ff\u28ff\u28ff\u28ff\u28ff\u28e6\u2880\u2847\u28a0\u28ff\u2846\u2800\u2800\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u2838\u285f\u28ff\u28ff\u28f4\u2857\u2810\u2880\u2800\u2800\u2880\u28a0\u28fb\u28ff\u28ff\u28ff\u28a6\u2800\u288b\u28e4\u28f6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f6\u28c4\u2840\u2800\u2800\u2800\u2801\u2800\u2800\u28fb\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u28f7\u28e8\u28ff\u28c7\u2890\u2800\u2800", "\u2840\u28fe\u28c4\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u2810\u2870\u28bf\u28ff\u28ff\u28ff\u28fc\u28e4\u28f6\u28f6\u28ff\u28f6\u28ff\u28ff\u28ff\u28ff\u2880\u2800\u289a\u28ed\u280d\u2809\u2809\u28ff\u285f\u2809\u2801\u2809\u2889\u2809\u2800\u2800\u2800\u2800\u2810\u2800\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u28ff\u28ff\u2847\u28ff\u28fe\u2844\u2800", "\u2806\u2809\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2820\u2808\u28e3\u28bb\u28fc\u28ff\u28ff\u28ff\u28ff\u28e7\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2813\u2801\u28b0\u28cf\u28e0\u28f6\u28f2\u28f6\u28ff\u2803\u2800\u28f4\u28f6\u2802\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u28fc\u28ff\u2847\u2800\u28fb\u28ff\u2844\u2842", "\u2801\u2800\u2820\u2898\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2888\u2800\u28fd\u2843\u283c\u28ff\u287f\u283f\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2807\u2800\u2800\u28fe\u28ff\u28ff\u28ff\u28ff\u281f\u281b\u2801\u2800\u28fc\u28ff\u28ff\u287f\u283f\u2802\u2800\u2800\u2800\u2800\u2808\u283b\u28ff\u28ff\u28ff\u28ff\u28f7\u28ff\u28ff\u28e5\u28e7\u28ff\u28ff\u28c7\u2843", "\u2800\u2800\u28b8\u28fd\u28f5\u2847\u2800\u2800\u2800\u2800\u2800\u2800\u2849\u2800\u28ff\u28c0\u2820\u28ff\u28e4\u285c\u28fb\u28bf\u28ff\u28ff\u28ff\u28ff\u280f\u2800\u2800\u2800\u28bb\u28ff\u28ff\u28ff\u281f\u2808\u28d1\u2800\u2800\u28b8\u28ff\u280b\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2818\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fb\u28c7", "\u2800\u2800\u28f8\u28ff\u28ff\u28c7\u2800\u2800\u2800\u2800\u2800\u28e0\u28c7\u2803\u2800\u2838\u2831\u288f\u28f8\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2846\u2800\u2800\u2800\u28b9\u28ff\u285f\u2801\u28c0\u28e4\u28e5\u2824\u2800\u2800\u2808\u2803\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a1\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2801\u281b\u28ff\u28ff\u2847\u2804\u28e6\u2882\u28f0\u2818\u284f\u2808\u2803\u2840\u2800\u2800\u2810\u28e1\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c4\u2800\u2800\u2838\u2808\u2839\u2803\u2818\u28bf\u2805\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2818", "\u2800\u2808\u2890\u28ff\u284f\u2887\u28e2\u28ff\u28ed\u287f\u2883\u2800\u2800\u2800\u2800\u2800\u2800\u2820\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ef\u28c1\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u280a\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u28b6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800", "\u2800\u2800\u28b8\u28ff\u28e3\u28fe\u28fd\u28ff\u28ff\u28cf\u2804\u2800\u28a0\u2800\u2820\u2802\u2800\u2880\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u285b\u2809\u2800\u2800\u2800\u2800\u28a2\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2802\u2876\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2844", "\u2800\u2800\u28b8\u2809\u28fe\u28ff\u284f\u28f7\u28ff\u28ff\u28c0\u28a0\u28ba\u28e7\u284e\u28e4\u28b0\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u280b\u2809\u28f4\u28f6\u28f6\u2876\u2804\u2838\u28bf\u28f6\u28c4\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u28b0\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2847", "\u28b8\u2840\u2808\u2828\u28b9\u28fb\u2803\u285f\u28ff\u28ff\u28ff\u28fe\u28ff\u28fe\u28ff\u28ff\u28f0\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800\u2800\u28f0\u28ff\u28ff\u28ff\u2803\u2800\u2800\u28ff\u28ff\u285f\u2881\u28c4\u2800\u2880\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u28f8\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2858\u281c\u2803", "\u2808\u2801\u2800\u2800\u28fc\u2818\u28b0\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u281b\u281b\u281b\u28cd\u28c5\u2800\u2800\u2800\u28c8\u28e9\u28ff\u2800\u2880\u28fc\u28ff\u28ff\u2864\u2808\u283f\u2818\u2802\u2800\u2800\u2880\u2800\u2800\u2800\u2800\u2800\u2880\u28ec\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2817\u2801\u2800", "\u2800\u2800\u2800\u2840\u280f\u2800\u28e6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u281b\u2801\u2800\u2800\u2800\u2800\u28a0\u2804\u2800\u2800\u2808\u2812\u280d\u28a0\u28dd\u28bf\u28ff\u287f\u28ff\u28e4\u2810\u288b\u2847\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u2809\u2819\u283b\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u287f\u28f7\u284e\u2830\u2800", "\u2800\u2800\u2808\u2800\u2800\u2800\u2847\u28ff\u28ff\u28ff\u28ff\u28ff\u285f\u2801\u2800\u2800\u2800\u28e0\u28f4\u28f6\u28e0\u2800\u2800\u2800\u2800\u2808\u2812\u2800\u2800\u2809\u2803\u2809\u2809\u2809\u2800\u28b7\u28df\u2845\u2800\u2800\u2838\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28f4\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fb\u28ff\u2806\u2880\u2800", "\u2844\u2800\u2800\u28c7\u28c4\u28f6\u28ab\u28bf\u28ff\u28ff\u28ff\u280f\u2860\u2800\u2800\u2800\u2800\u28e0\u28e4\u28ee\u2844\u2801\u2800\u2800\u2830\u2802\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2844\u28