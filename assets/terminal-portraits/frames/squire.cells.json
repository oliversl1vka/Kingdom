{"w": 64, "h": 48, "braille": ["\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2884\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u28f4\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2845\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2870\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u2834\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28c0\u28c0\u28e4\u28f4\u28e4\u28e4\u28f9\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28e6\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2840\u28b8\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u28b3\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u2840\u2800\u2800\u2800\u2800\u28f4\u2846\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2806\u2811\u282e\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2840\u2800\u2800\u2800\u2889\u2878\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2809\u28b1\u28ff\u28fb\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ee\u28ff\u28fe\u28df\u2847\u2800\u28e0\u2844\u28ff\u28ff\u2807\u2800\u2800\u2800\u2800\u28a0\u2844\u2800\u2808\u2801\u2800\u2800\u28e7", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2801\u2800\u2800\u28a0\u28bf\u2846\u2800\u2800\u2800\u2800\u2800\u2880\u2884\u28de\u28e4\u28f4\u28ee\u28ec\u28fd\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28ba\u2857\u28b8\u285f\u2801\u2840\u2800\u2800\u2800\u2800\u2800\u28f2\u2844\u28b0\u28c6\u28df\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2818\u2800\u2800\u2800\u2880\u28e0\u2874\u28ff\u287f\u2809\u2801\u2808\u2801\u2809\u2809\u283b\u283f\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u2847\u2800\u28bf\u2803\u28b8\u2847\u2800\u28fd\u2805\u2800\u2800\u28a0\u2840\u28ff\u2866\u283f\u288b\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u2846\u2800\u2800\u2800\u2880\u28e4\u2876\u280b\u2800\u283c\u2803\u2800\u2800\u2800\u2800\u2800\u2800\u2818\u28c6\u2800\u28b9\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ec\u2840\u281c\u28a0\u2838\u2802\u2800\u283a\u2800\u2800\u28a0\u28fc\u28ff\u28df\u2874\u28b0\u2838\u28fe\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u28fe\u28f6\u28e7\u287e\u28e7\u2800\u2800\u28b0\u28ff\u280f\u2800\u2800\u2800\u2810\u2828\u2880\u2840\u28a6\u28c0\u2834\u2864\u2823\u28bc\u287f\u28ee\u2849\u2808\u28bf\u28ff\u28ff\u28fe\u28f7\u28ff\u28ff\u28fd\u28c4\u2801\u28b0\u2800\u2840\u2847\u2800\u2800\u28c2\u2828\u2811\u28ff\u28ff\u28ff\u28ff\u28cf\u28fb", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2818\u28ff\u28ff\u2847\u2800\u2809\u2800\u28a0\u28ff\u2801\u2800\u2800\u2800\u2846\u28e4\u2800\u28a0\u2879\u28f7\u287b\u28e4\u2839\u28c6\u2800\u2801\u2800\u2831\u287c\u28fe\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800\u28fc\u28fc\u2877\u2847\u2800\u2800\u2801\u2880\u287f\u28ff\u28ff\u28ff\u28ef\u2847\u28be", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u283b\u287f\u28e7\u28a0\u28e6\u28f4\u28fe\u28ff\u2800\u2800\u2800\u2800\u28d4\u28ff\u28f7\u28ec\u28ff\u28fe\u287f\u283f\u283f\u2836\u28f6\u28e6\u2840\u2820\u2800\u2800\u2880\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7\u28ff\u28b7\u2806\u2821\u2800\u28c0\u28b0\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28fc", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2803\u2888\u28fc\u28ff\u28ff\u28ff\u2809\u2800\u2800\u2800\u2880\u28c9\u2809\u2809\u28bf\u28ff\u28ff\u2836\u2812\u289a\u287f\u28bf\u28ff\u2877\u2800\u2800\u2801\u28be\u28fb\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28b0\u28b0\u2876\u28f7\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2803\u2800\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2840\u2802\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u2800\u28b8\u2801\u28a0\u28f4\u2844\u28b8\u28ff\u28ff\u28ff\u28fe\u28ff\u28f7\u28ff\u28ff\u28f7\u2806\u2800\u2800\u2800\u28b9\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28b8\u28cc\u28f1\u28f6\u28ff\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28a0\u28ff", "\u2800\u2800\u28e4\u2844\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2847\u2880\u28ff\u28ff\u28ff\u28ff\u28ff\u28e7\u2800\u2800\u2888\u28f4\u28fe\u28ff\u28cf\u283e\u28ff\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c6\u28c4\u28f8\u28e6\u2808\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ef\u2800\u28b8\u2848", "\u2800\u2800\u28a9\u2804\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2819\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2840\u2800\u28b8\u2848\u28bf\u28ff\u284f\u2880\u28fd\u28f7\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2807\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28bf\u28ff\u28ff\u28ff\u28ff\u2887\u2800\u28bd\u28d5", "\u2800\u2840\u2846\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c4\u285e\u28c7\u28f8\u28ff\u281f\u288b\u28ed\u28ed\u28fd\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2807\u2809\u2880\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2877\u284f\u28ff\u28ff\u28ff\u28ff\u2847\u2800\u28f8\u2847", "\u2800\u28f2\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2816\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28e6\u28b9\u28ff\u28ff\u28ff\u28fe\u28e4\u28ec\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u28fb\u2802\u28a0\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c7\u2880\u28ff\u28ef\u28e9\u285f\u284f\u2800\u28ff\u2847", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28e4\u28e0\u28e0\u2844\u28c4\u28dc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2837\u281f\u281a\u2837\u28df\u283f\u283f\u28bf\u283f\u281f\u280b\u2889\u28fc\u28ff\u28f4\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7\u28fe\u28ff\u28e7", "\u2800\u2800\u2800\u2800\u2800\u2820\u2840\u2800\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2803\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28e0\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28cf\u28fb\u28ff\u2833", "\u2800\u2800\u2800\u28c0\u2818\u28b6\u28f7\u28f6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u280b\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2810\u28a4\u285c\u28bf\u28ff\u28ff\u287f\u283b\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7", "\u2800\u2810\u28c7\u28f8\u2892\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28df\u283f\u283f\u2804\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u28bb\u28ff\u28ff\u2803\u2800\u2800\u2809\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u28ff\u28ff\u28ff\u285f", "\u2800\u2800\u28fe\u28ff\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u283f\u283f\u283f\u282f\u280d\u2809\u281b\u2802\u2810\u2800\u2800\u2800\u2800\u2800\u2800\u2802\u2844\u2800\u2800\u2800\u2800\u2818\u28bf\u28