{"w": 64, "h": 48, "braille": ["\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2820\u2846\u2800\u2800\u2800\u28a8\u2800\u2800\u2807\u28f8\u28ff\u2867\u28fc\u28cb\u2820\u28ed\u28e7\u28c4\u28b8\u2840\u2880\u2898\u2803\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28fc\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28a0\u28d7\u28c6\u2860\u28e6\u28ff\u28ff\u28e7\u28c6\u28ff\u28f6\u28cf\u28b0\u28ff\u28e7\u28ff\u28ff\u28ff\u28ff\u28f7\u28fe\u288a\u28e4\u2802", "\u2800\u2800\u2818\u2800\u2800\u2800\u2800\u2800\u2800\u2820\u28a0\u28ff\u2846\u28b8\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28f0\u28c4\u2880\u2840\u2880\u28ec\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2858\u289f\u2800", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2830\u287c\u281a\u28c7\u285e\u2802\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2840\u2800\u2800\u2880\u28c4\u28e0\u28c0\u2840\u2800\u28b4\u28c4\u28f7\u284f\u283f\u287e\u28ff\u28df\u28bd\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u2846", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2801\u2800\u28ff\u2800\u2838\u2840\u2800\u28e0\u28c4\u28e0\u28e0\u28e6\u2800\u2888\u2853\u28ef\u28ff\u28ff\u28ff\u28ff\u28f7\u28d6\u28e4\u28ff\u28ff\u2800\u2800\u281b\u28bf\u284c\u288f\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2877", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2800\u2800\u2800\u2839\u2844\u2800\u28b9\u28a0\u28fd\u28ff\u28ff\u28ff\u28ff\u2874\u280b\u28a9\u2849\u28ff\u28ff\u28ff\u28ff\u28e7\u28ff\u28ff\u28ff\u283f\u2820\u28c0\u2840\u28c0\u28e5\u289f\u28c8\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u2800\u2800\u2800\u2803\u2803\u2800\u28b8\u28a4\u284f\u2839\u28ff\u28ff\u28ff\u2847\u2800\u2893\u28bf\u28ee\u287b\u283f\u28db\u28f9\u28ed\u28fd\u28f7\u28fe\u28ff\u28ff\u28ff\u28ff\u2857\u281f\u2880\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2840\u2899\u28f7\u2800\u2888\u283b\u28ff\u2807\u2820\u280b\u2800\u28df\u287b\u28ff\u287f\u283f\u28df\u28ff\u28ee\u28ff\u28b7\u287f\u280b\u28e9\u28e4\u28fe\u28b1\u2878\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2880\u2800\u28f2\u28ff\u2844\u281b\u2800\u2808\u2844\u2800\u2809\u2800\u2810\u2882\u28c3\u28ff\u28dc\u2876\u283f\u28d9\u28f9\u28ff\u28f4\u28f6\u28ff\u284b\u289d\u28ff\u287f\u28ae\u28cf\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2820\u2800\u2800\u28b8\u28e6\u28ff\u28ff\u28e7\u2800\u2800\u2800\u2800\u2800\u2806\u2800\u2808\u2808\u2809\u28e0\u28f4\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u283f\u28ef\u28b7\u28ce\u288b\u2813\u28b0\u2878\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2810\u2802\u2890\u2800\u28b8\u28fc\u28ff\u28ff\u28ff\u28c7\u2800\u2800\u2800\u2800\u2800\u2807\u2800\u2800\u28a0\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28df\u28ef\u28a7\u28df\u283b\u28ff\u28e6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2838\u28c6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c6\u2800\u2800\u2800\u2820\u2804\u2800\u2801\u28c8\u287f\u28ff\u28ff\u28ff\u287f\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2859\u28aa\u2844\u28ff\u282b\u289c\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28b0\u285f\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800\u2800\u2800\u2800\u2810\u2800\u2800\u2800\u2800\u28dd\u28bf\u28ff\u28ff\u28f6\u28fe\u28fd\u283f\u28ff\u28ff\u28f6\u28ee\u28ff\u2893\u2816\u2800\u28b7\u28bb\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2804\u2800\u2800\u28ec\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28c7\u2800\u2800\u2800\u2800\u2800\u2800\u281a\u28a6\u28fd\u28de\u28f9\u28ff\u28ff\u28fd\u28f6\u28fb\u28eb\u285b\u28ff\u28f5\u287b\u28c6\u2889\u2800\u2808\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u2880\u2870\u28f6\u28e7\u2878\u2880\u285c\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2840\u2800\u2800\u2800\u2808\u2800\u2800\u2858\u28bf\u28df\u28ff\u28ff\u28ff\u28ff\u28ff\u28fe\u287f\u28ff\u2888\u2859\u2803\u28bb\u2844\u28b7\u28c5\u28fd\u2829\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u28b8\u28b8\u28ff\u28ff\u28e7\u28fc\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2867\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2882\u28fe\u28db\u287f\u283f\u281b\u280b\u28c1\u28dc\u28fd\u28fd\u28ff\u28ef\u2843\u28bb\u281a\u289b\u2801\u28c2\u2839\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u28b8\u28b8\u28fe\u28ff\u28df\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7\u2800\u2800\u2800\u2800\u2802\u2808\u2813\u280b\u2809\u2800\u28c0\u28f0\u28f6\u283e\u289f\u28e9\u28f4\u28fe\u28ff\u28ff\u28ff\u2858\u2846\u28bd\u285c\u28be\u28e6\u28fd\u281b\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u28ff\u28de\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28e7\u2800\u2800\u2800\u2800\u2800\u2804\u2820\u2812\u281b\u2809\u2840\u28e4\u28fe\u28ff\u28df\u28d9\u28ff\u28ff\u28ff\u28ff\u28c7\u2820\u2800\u2839\u28ee\u281f\u2823\u2808\u281b\u283f\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u2800\u28ff\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u289b\u28ff\u28df\u28bf\u28c7\u2800\u2800\u2800\u2801\u2804\u2800\u2800\u2800\u2800\u2818\u283b\u288e\u28c9\u28ff\u28ff\u280b\u28fb\u28ff\u28ff\u28ff\u2847\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2809\u281b\u28bf\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u28b0\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800\u28db\u28fe\u28ff\u2801\u28fb\u2846\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2812\u283a\u28ff\u28c9\u28fb\u28ff\u281b\u28ff\u28ff\u28ff\u28e7\u2808\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u283b\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff", "\u2800\u2800\u2800\u288a\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2840\u2811\u281b\u2809\u2800\u28fe\u28ff\u2844\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2812\u280f\u2809\u28e9\u28ff\u287f\u28bf\u28ff\u28ff\u2807\u2861\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2801\u2802\u2800\u2800\u2800\u2800\u2800\u2819\u2819\u283b\u28ff\u28ff", "\u2800\u2860\u2804\u28fe\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2800\u28fd\u2847\u28ff\u28ff\u28ff\u28f7\u2800\u2800\u2800\u2800\u2840\u2800\u2800\u2800\u2800\u2804\u2829\u283d\u2889\u28bb\u289b\u283e\u289f\u2834\u280b\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2839\u283f", "\u2822\u28c0\u28f6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u281f\u28c0\u28ff\u28e7\u28ff\u287f\u2809\u2800\u2800\u2800\u2800\u2800\u2881\u2800\u2800\u2800\u2800\u2800\u2804\u2800\u28c0\u2889\u2872\u2812\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2808\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28f6\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u283f\u28ff\u28be\u28ff\u28d3\u2809\u2809\u2809\u28b8\u28ff\u28f6\u28f6\u2826\u2816\u2800\u2800\u2808\u2802\u2800\u2800\u2800\u2800\u2880\u2824\u2818\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u285f\u28b8\u28ff\u28a1\u28b4\u28f6\u28ef\u28f6\u28f6\u28f6\u28e6\u28cd\u2840\u2800\u2800\u2800\u2800\u2800\u2808\u2800\u2808\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u2803\u28ff\u28ff\u2818\u2812\u2809\u2809\u280b\u2800\u2898\u280b\u280b\u280b\u2806\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28e7\u2800\u2800\u284c\u2842\u2800\u2832\u283e\u2836\u283f\u287f\u281f\u2822\u2844\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2800\u2800\u2884\u28f4\u2800\u2808\u2800\u2800\u28c0\u28e0\u28c4\u28c0\u2840\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u281f\u2803\u2800\u2800\u2800\u2819\u2803\u2800\u2800\u2809\u2809\u2811\u280e\u2809\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u287f\u2801\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2840\u28c0\u28c0\u2840\u2800\u2800\u28c0\u28e4\u2840\u2800\u2800\u2800\u2800\u2804\u2800\u2830\u2806\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800", "\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28ff\u28a1\u2847\u2800\u2800\u2800\u2800\u2820\u28e4\u2810\u28ff\u28ff\u28ff\u28ff\u28ff\u28f7\u28f6\u28e6\u28dd\u28ff\u2800\u2800\u2800\u2800\u2830\u2804\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u2800\u28